{
  "name": "wdfriend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "有记忆的 AI 朋友",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:front\"",
    "dev:api": "vercel dev --listen 3001",
    "dev:front": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:front": "cd frontend && npx vue-tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "openai": "^4.70.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0",
    "vercel": "^37.0.0"
  }
}
